{
  "compilerOptions": {
    "target": "ES6",
    "module": "esnext",
    "lib": [
      "ES6",
      "DOM"
    ],
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": true
  },
  "include": [
    "./static/src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
